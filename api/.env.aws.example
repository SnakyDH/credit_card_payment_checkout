# Copy to .env.aws and fill in your values before running scripts/aws-deploy.sh
# AWS credentials (optional if already configured via `aws configure`)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Database (auto-generated by deploy script if left empty)
# DB_PASSWORD=
# DB_USERNAME=postgres
# DB_DATABASE=products-api

# Payment Gateway (required for transactions)
PAYMENT_GATEWAY_API_URL=
PAYMENT_GATEWAY_PUBLIC_KEY=
PAYMENT_GATEWAY_PRIVATE_KEY=
PAYMENT_GATEWAY_EVENTS_KEY=
PAYMENT_GATEWAY_INTEGRITY_KEY=

# Unsplash (required for product seed)
UNSPLASH_API_URL=https://api.unsplash.com
UNSPLASH_ACCESS_KEY=
